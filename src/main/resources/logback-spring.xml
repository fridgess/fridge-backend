<?xml version="1.0" encoding="UTF-8" ?>
<!-- logback-spring.xml -->

<!--로그 세팅-->
<!--60초마다 설정 파일의 변경을 확인하여 변경 시 갱신-->
<configuration scan="true" scanPeriod="60 seconds">
  <include resource="org/springframework/boot/logging/logback/defaults.xml"/>

  <!--  Logback 내부 상태 로그 (필요 시 주석 해제 후 사용) -->
  <!--  <statusListener class="ch.qos.logback.core.status.OnConsoleStatusListener"/>-->

  <!--    프로파일 별 로그 개별 설정 -->
  <springProfile name="dev">
    <property name="LOG_PATH" value=".logs"/>
  </springProfile>

  <!--  Environment 내 프로퍼티 개별적으로 설정 -->
  <springProperty scope="context" name="LOG_LEVEL" source="logging.level.root"/>

  <!--  log file name -->
  <property name="LOG_FILE_NAME" value="log"/>
  <!--  err log file name -->
  <property name="ERR_LOG_FILE_NAME" value="err_log"/>
  <!-- console log pattern -->
  <property name="CONSOLE_LOG_PATTERN"
    value="[%d{yyyy-MM-dd HH:mm:ss.SSS}:%-3relative]  %highlight(%-5level) %clr(${PID:-}){magenta} %clr(---){faint} %clr([%15.15thread]){faint} %clr([%X{requestId:-}]){yellow} %clr(%X{method:-}){green} %clr(%X{uri:-}){magenta} %clr(%-40.40logger{36}){cyan} %clr(:){faint} %msg%n"/>
  <!-- file log pattern -->
  <property name="FILE_LOG_PATTERN"
    value="[%d{yyyy-MM-dd HH:mm:ss}:%-3relative] %-5level ${PID:-} --- [%15.15thread] [%X{requestId:-}] %X{method:-} %X{uri:-} %-40.40logger{36} : %msg%n"/>

  <!--    콘솔로 출력 -->
  <appender name="CONSOLE" class="ch.qos.logback.core.ConsoleAppender">
    <encoder class="ch.qos.logback.classic.encoder.PatternLayoutEncoder">
      <pattern>${CONSOLE_LOG_PATTERN}</pattern>
      <charset>UTF-8</charset>
    </encoder>
  </appender>

  <!--    파일로 출력 -->
  <appender name="FILE" class="ch.qos.logback.core.rolling.RollingFileAppender">
    <file>${LOG_PATH}/${LOG_FILE_NAME}.log</file>

    <!--    출력 패턴 설정 -->
    <encoder class="ch.qos.logback.classic.encoder.PatternLayoutEncoder">
      <pattern>${FILE_LOG_PATTERN}</pattern>
      <charset>UTF-8</charset>
    </encoder>

    <!--    Rolling 정책 -->
    <rollingPolicy class="ch.qos.logback.core.rolling.SizeAndTimeBasedRollingPolicy">
      <fileNamePattern>${LOG_PATH}/${LOG_FILE_NAME}.%d{yyyy-MM-dd}_%i.gz</fileNamePattern>
      <!--        파일당 최고 용량 -->
      <maxFileSize>10KB</maxFileSize>
      <!--      일자별 로그 파일 최대 보관주기 (day) -->
      <maxHistory>30</maxHistory>
      <!--      전체 크기 제한 초과 시 가장 오래된 파일 삭제 -->
      <totalSizeCap>1GB</totalSizeCap>
    </rollingPolicy>
  </appender>

  <!--  에러의 경우, 파일에 로그 처리 -->
  <appender name="ERROR" class="ch.qos.logback.core.rolling.RollingFileAppender">
    <filter class="ch.qos.logback.classic.filter.LevelFilter">
      <level>error</level>
      <onMatch>ACCEPT</onMatch>
      <onMismatch>DENY</onMismatch>
    </filter>
    <file>${LOG_PATH}/${ERR_LOG_FILE_NAME}.log</file>
    <encoder class="ch.qos.logback.classic.encoder.PatternLayoutEncoder">
      <pattern>${FILE_LOG_PATTERN}</pattern>
    </encoder>

    <!--    Rolling 정책 -->
    <rollingPolicy class="ch.qos.logback.core.rolling.SizeAndTimeBasedRollingPolicy">
      <fileNamePattern>${LOG_PATH}/${ERR_LOG_FILE_NAME}.%d{yyyy-MM-dd}_%i.gz</fileNamePattern>
      <!--        파일당 최고 용량 -->
      <maxFileSize>10KB</maxFileSize>
      <!--      일자별 로그 파일 최대 보관주기 (day) -->
      <maxHistory>60</maxHistory>
    </rollingPolicy>
  </appender>

  <!--  ROOT 레벨 설정  -->
  <root level="${LOG_LEVEL}">
    <appender-ref ref="CONSOLE"/>
    <appender-ref ref="FILE"/>
    <appender-ref ref="ERROR"/>
  </root>

  <!--  패키지별 다른 레벨 설정: 디버그가 필요한 Service-->
  <!--    <logger name="com.fridge.fridgebackend.domain" level="DEBUG"/>-->
</configuration>
